// Synapse database schema
// Source of truth for the platform. Auth.js models + multi-tenant workspace model
// + the transactional Outbox used by the event-driven backbone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Auth.js (NextAuth) models
// ----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // local credentials login (hashed); null for pure-OAuth users
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  assignedCards Card[]       @relation("CardAssignee")
  notifications Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ----------------------------------------------------------------------------
// Multi-tenant workspace model
// ----------------------------------------------------------------------------

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectType {
  BOARD
  DOC
  CANVAS
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner       User         @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  memberships Membership[]
  projects    Project[]
  invitations Invitation[]
  activities  Activity[]

  @@index([ownerId])
  @@map("workspaces")
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

model Project {
  id          String      @id @default(cuid())
  name        String
  type        ProjectType @default(BOARD)
  workspaceId String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns   BoardColumn[]
  cards     Card[]
  document  Document?

  @@index([workspaceId])
  @@map("projects")
}

// ----------------------------------------------------------------------------
// Faz 3 — Docs. A DOC-type project owns one collaborative document whose state
// is the binary Yjs CRDT snapshot, persisted by the realtime server.
// ----------------------------------------------------------------------------

model Document {
  projectId String   @id
  state     Bytes
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ----------------------------------------------------------------------------
// Faz 2 — Boards (Kanban). A BOARD-type project owns ordered columns; each
// column owns ordered cards. `position` is a 0-based ordering index maintained
// by the board API on create/move.
// ----------------------------------------------------------------------------

model BoardColumn {
  id        String   @id @default(cuid())
  projectId String
  name      String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@index([projectId, position])
  @@map("board_columns")
}

model Card {
  id          String   @id @default(cuid())
  projectId   String
  columnId    String
  title       String
  description String?
  position    Int
  assigneeId  String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column   BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee User?       @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([columnId, position])
  @@index([projectId])
  @@map("cards")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// Pending invitation: created even when the invitee has no account yet. Accepting
// (via the token link) materialises a Membership.
model Invitation {
  id          String       @id @default(cuid())
  workspaceId String
  email       String
  role        Role         @default(MEMBER)
  token       String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  invitedById String
  createdAt   DateTime     @default(now())
  expiresAt   DateTime

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([email])
  @@map("invitations")
}

// Activity timeline entry, written by the Activity service consuming Kafka events.
model Activity {
  id          String   @id @default(cuid())
  workspaceId String
  type        String
  actorId     String?
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("activities")
}

// ----------------------------------------------------------------------------
// Transactional Outbox — written in the same DB transaction as domain changes,
// then relayed to Kafka by the outbox publisher. Guarantees no lost events.
// ----------------------------------------------------------------------------

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

model OutboxEvent {
  id            String       @id @default(cuid())
  // logical Kafka topic / aggregate stream, e.g. "project", "task"
  aggregateType String
  aggregateId   String
  // event name, e.g. "ProjectCreated"
  eventType     String
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  createdAt     DateTime     @default(now())
  publishedAt   DateTime?

  @@index([status, createdAt])
  @@map("outbox_events")
}

// Consumer-side idempotency ledger: records which (consumer, eventId) pairs were
// already processed so re-delivered Kafka messages produce no duplicate effects.
model ProcessedEvent {
  consumer    String
  eventId     String
  processedAt DateTime @default(now())

  @@id([consumer, eventId])
  @@map("processed_events")
}

// ----------------------------------------------------------------------------
// Faz 5 — Platform services: audit, notifications, analytics. Each is written by
// its own Kafka consumer service from the shared event stream.
// ----------------------------------------------------------------------------

// Immutable audit trail of every domain event (written by the audit service).
model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  eventType   String
  eventId     String
  actorId     String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}

// Per-user notifications (written by the notification service).
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// Rolled-up event counts per workspace/day/type (written by the analytics service).
model DailyMetric {
  workspaceId String
  day         String
  eventType   String
  count       Int    @default(0)

  @@id([workspaceId, day, eventType])
  @@map("daily_metrics")
}
